---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Carlos Yuyes | DevSecOps & SysAdmin">
	<nav>
		<div class="logo">rexar@arch:~#</div>
		<button class="menu-btn" id="menu-btn" aria-label="Abrir menú">
			<span></span>
			<span></span>
			<span></span>
		</button>
		<ul id="nav-menu">
			<li><a href="#inicio">Inicio</a></li>
			<li><a href="#servicios">Servicios</a></li>
			<li><a href="#habilidades">Habilidades</a></li>
			<li><a href="#contacto">Contacto</a></li>
		</ul>
	</nav>

	<header id="inicio">
		<div class="profile-container">
			<div class="profile-img"></div>
		</div>
		
		<h1>Hola, soy <span class="text-gradient">Carlos Yuyes</span></h1>
		
		<div class="typewriter-container">
			Especialista en <span id="text"></span><span class="cursor">|</span>
		</div>

		<div class="monitor-panel">
			<div class="panel-header">
				<div class="dot red"></div>
				<div class="dot yellow"></div>
				<div class="dot green"></div>
				<span class="panel-title">centinela_core_monitor.sh</span>
			</div>
			<div class="panel-grid">
				<div class="panel-stat">
					<span class="label">> ESTADO_SISTEMA:</span>
					<span class="value green-text">OPERATIVO // SEGURO</span>
				</div>
				<div class="panel-stat">
					<span class="label">> FIREWALL_IPS:</span>
					<span class="value green-text">MITIGANDO_ATAQUES [ACTIVO]</span>
				</div>
				<div class="panel-stat">
					<span class="label">> INSPECCION_CONTENEDORES:</span>
					<span class="value cyan-text">DOCKER_SWARM // 0_ALERTAS</span>
				</div>
				<div class="panel-stat">
					<span class="label">> ALERTA_VULNERABILIDAD:</span>
					<span class="value red-text">SISTEMA_PARCHEADO [OK]</span>
				</div>
			</div>
		</div>
	</header>

	<main>
		<section id="servicios">
			<h2>Servicios Profesionales</h2>
			<p class="section-subtitle">Soluciones de infraestructura de alta disponibilidad y automatización robusta</p>
			<div class="grid">
				<div class="card">
					<div class="card-icon">🔐</div>
					<h3>Auditoría de Ciberseguridad</h3>
					<p>Blindaje de servidores Linux, hardening de entornos de producción y escaneo continuo de vulnerabilidades críticas.</p>
				</div>
				<div class="card">
					<div class="card-icon">🐳</div>
					<h3>Cultura DevOps & CI/CD</h3>
					<p>Automatización de despliegues y empaquetamiento de aplicaciones mediante pipelines modernos e inyecciones seguras.</p>
				</div>
				<div class="card">
					<div class="card-icon">🐧</div>
					<h3>Administración SysAdmin</h3>
					<p>Gestión avanzada de servidores corporativos en entornos Linux, optimización de recursos y tuning de bases de datos.</p>
				</div>
			</div>
		</section>

		<section id="habilidades">
			<h2>Stack Tecnológico</h2>
			<p class="section-subtitle">Herramientas y tecnologías que domino para la protección de entornos</p>
			<div class="skills-wrapper">
				<span class="skill-tag">Linux (Ubuntu/Debian/RHEL)</span>
				<span class="skill-tag">Docker & Kubernetes</span>
				<span class="skill-tag">Cybersecurity Hardening</span>
				<span class="skill-tag">DevOps Pipelines</span>
				<span class="skill-tag">Bash & Python Scripting</span>
				<span class="skill-tag">Git & GitHub Actions</span>
				<span class="skill-tag">Cloud Infrastructure</span>
				<span class="skill-tag">Proxmox VE</span>
			</div>
		</section>

		<section id="contacto">
			<h2>Conectemos</h2>
			<p class="section-subtitle">¿Tienes un servidor comprometido o necesitas automatizar tu arquitectura? Escríbeme.</p>
			<form action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
				<input type="text" name="name" placeholder="Tu Nombre o Empresa" required />
				<input type="email" name="email" placeholder="Tu Correo Electrónico" required />
				<textarea name="message" rows="5" placeholder="Cuéntame sobre el requerimiento de tu proyecto..." required></textarea>
				<button type="submit">Enviar Mensaje Seguro</button>
			</form>
		</section>
	</main>
</Layout>

<style>
	/* --- VARIABLES GLOBALES --- */
	:root {
		--bg-color: #0d0b14;
		--accent-purple: #bf5af2;
		--accent-cyan: #00e5ff;
		--text-color: #ebebf5;
		--card-bg: rgba(255, 255, 255, 0.03);
		--glass: rgba(13, 11, 20, 0.95);
		--neon-green: #39ff14;
	}

	/* Asegurar que todo use border-box para evitar desbordamientos en móviles */
	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
	}

	/* --- NAVEGACIÓN --- */
	nav {
		position: fixed;
		top: 0;
		width: 100%;
		z-index: 1000;
		background: var(--glass);
		backdrop-filter: blur(15px);
		border-bottom: 1px solid rgba(191, 90, 242, 0.15);
		padding: 1rem 5%;
		display: flex;
		justify-content: space-between;
		align-items: center;
		height: 70px;
	}
	.logo {
		font-family: monospace;
		font-weight: 700;
		color: var(--neon-green);
		font-size: 1.1rem;
		text-shadow: 0 0 8px rgba(57, 255, 20, 0.4);
	}
	nav ul {
		display: flex;
		list-style: none;
		gap: 2rem;
	}
	nav a {
		text-decoration: none;
		color: var(--text-color);
		font-weight: 500;
		transition: 0.3s;
		font-size: 0.95rem;
	}
	nav a:hover {
		color: var(--accent-cyan);
		text-shadow: 0 0 10px var(--accent-cyan);
	}
	
	/* Botón Hamburguesa */
	.menu-btn {
		display: none;
		cursor: pointer;
		flex-direction: column;
		gap: 6px;
		border: none;
		background: none;
		z-index: 1100;
		padding: 5px;
	}
	.menu-btn span {
		width: 25px;
		height: 2px;
		background: var(--accent-cyan);
		transition: 0.3s;
		display: block;
	}

	/* --- HERO & PANEL --- */
	header {
		min-height: 100vh;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 100px 5% 40px 5%;
	}
	.profile-container {
		position: relative;
		margin-bottom: 1.5rem;
	}
	.profile-img {
		width: 140px;
		height: 140px;
		border-radius: 50%;
		border: 3px solid var(--accent-purple);
		box-shadow: 0 0 30px rgba(191, 90, 242, 0.4);
		background-image: url("/perfil.jpg");
		background-size: cover;
		background-position: center;
	}
	h1 {
		font-size: clamp(2rem, 6vw, 3.5rem);
		margin-bottom: 0.5rem;
		font-weight: 800;
		line-height: 1.2;
	}
	.text-gradient {
		background: linear-gradient(45deg, var(--accent-cyan), var(--accent-purple));
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.typewriter-container {
		font-family: monospace;
		font-size: clamp(1rem, 3vw, 1.25rem);
		color: var(--text-color);
		margin-bottom: 2rem;
		min-height: 1.5em;
	}
	#text {
		color: var(--accent-cyan);
		font-weight: bold;
	}
	.cursor {
		animation: blink 0.8s infinite;
		color: var(--accent-purple);
		font-weight: bold;
	}

	/* MONITOR CENTINELA RESPONSIVO */
	.monitor-panel {
		width: 100%;
		max-width: 650px;
		background: #110f18;
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		box-shadow: 0 20px 50px rgba(0,0,0,0.6);
		text-align: left;
		font-family: monospace;
		overflow: hidden;
	}
	.panel-header {
		background: #1a1724;
		padding: 0.7rem 1rem;
		display: flex;
		align-items: center;
		border-bottom: 1px solid rgba(255, 255, 255, 0.05);
	}
	.dot {
		width: 10px;
		height: 10px;
		border-radius: 50%;
		margin-right: 6px;
	}
	.red { background: #ff5f56; }
	.yellow { background: #ffbd2e; }
	.green { background: #27c93f; }
	.panel-title {
		font-size: 0.8rem;
		color: #928f9c;
		margin-left: 10px;
	}
	.panel-grid {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1rem;
		padding: 1.2rem;
	}
	.panel-stat {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}
	.label {
		font-size: 0.75rem;
		color: #928f9c;
	}
	.value {
		font-size: 0.9rem;
		font-weight: 500;
		word-break: break-all;
	}
	.green-text { color: var(--neon-green); text-shadow: 0 0 8px rgba(57, 255, 20, 0.2); }
	.red-text { color: #ff5555; text-shadow: 0 0 8px rgba(255, 85, 85, 0.2); }
	.cyan-text { color: var(--accent-cyan); }

	/* --- SECCIONES GLOBALES --- */
	section {
		padding: 80px 5%;
		max-width: 1200px;
		margin: 0 auto;
	}
	h2 {
		font-size: clamp(1.8rem, 4vw, 2.5rem);
		margin-bottom: 0.5rem;
		text-align: center;
		color: var(--accent-purple);
	}
	.section-subtitle {
		text-align: center;
		color: #928f9c;
		margin-bottom: 3rem;
		font-size: 0.95rem;
		padding: 0 5%;
	}

	/* --- STACK TECNOLÓGICO --- */
	.skills-wrapper {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 0.8rem;
		max-width: 800px;
		margin: 0 auto;
	}
	.skill-tag {
		padding: 0.6rem 1.2rem;
		background: rgba(191, 90, 242, 0.03);
		border: 1px solid rgba(191, 90, 242, 0.25);
		border-radius: 8px;
		font-family: monospace;
		font-size: 0.9rem;
		transition: 0.3s;
	}
	.skill-tag:hover {
		border-color: var(--accent-cyan);
		background: rgba(0, 229, 255, 0.05);
		transform: translateY(-2px);
	}

	/* --- SERVICIOS GRID --- */
	.grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
	}
	.card {
		background: var(--card-bg);
		border: 1px solid rgba(255, 255, 255, 0.05);
		padding: 2.2rem 1.8rem;
		border-radius: 16px;
		transition: 0.3s;
	}
	.card-icon {
		font-size: 2.2rem;
		margin-bottom: 1rem;
	}
	.card h3 {
		font-size: 1.2rem;
		margin-bottom: 0.8rem;
		color: #fff;
	}
	.card p {
		color: #928f9c;
		font-size: 0.95rem;
		line-height: 1.5;
	}
	.card:hover {
		transform: translateY(-5px);
		border-color: var(--accent-purple);
		box-shadow: 0 10px 25px rgba(191, 90, 242, 0.1);
	}

	/* --- CONTACTO FORM --- */
	form {
		max-width: 550px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1rem;
		width: 100%;
	}
	input, textarea {
		background: #14121f;
		border: 1px solid rgba(255, 255, 255, 0.08);
		padding: 1rem;
		color: white;
		border-radius: 10px;
		font-family: inherit;
		font-size: 0.95rem;
		width: 100%;
	}
	input:focus, textarea:focus {
		outline: none;
		border-color: var(--accent-cyan);
	}
	button {
		background: var(--accent-purple);
		color: white;
		border: none;
		padding: 1rem;
		font-weight: bold;
		font-size: 1rem;
		border-radius: 10px;
		cursor: pointer;
		transition: 0.3s;
	}
	button:hover {
		box-shadow: 0 0 20px rgba(191, 90, 242, 0.4);
	}

	/* --- 📱 MEDIA QUERIES RESPONSIVAS --- */
	@media (max-width: 768px) {
		nav {
			padding: 0 6%;
		}
		.menu-btn {
			display: flex; /* Muestra el botón de hamburguesa */
		}
		
		/* Menú se transforma en pantalla completa oculta */
		nav ul {
			display: none;
			position: fixed;
			top: 0;
			left: 0;
			width: 100%;
			height: 100vh;
			background: rgba(13, 11, 20, 0.98);
			backdrop-filter: blur(20px);
			flex-direction: column;
			justify-content: center;
			align-items: center;
			gap: 2.5rem;
			z-index: 1000;
		}
		
		/* Clase activa que se inyecta con JS */
		nav ul.show {
			display: flex;
		}

		/* Cambiar el Grid del Panel Centinela a 1 sola columna en celular */
		.panel-grid {
			grid-template-columns: 1fr;
			gap: 0.8rem;
			padding: 1rem;
		}
		
		/* Animación básica del menú hamburguesa */
		.menu-btn.open span:nth-child(1) {
			transform: translateY(8px) rotate(45deg);
		}
		.menu-btn.open span:nth-child(2) {
			opacity: 0;
		}
		.menu-btn.open span:nth-child(3) {
			transform: translateY(-8px) rotate(-45deg);
		}
	}

	@keyframes blink { 50% { opacity: 0; } }
</style>

<script>
	// Lógica del Escritor Automático (Typewriter)
	const words = ["Ciberseguridad", "Administración Linux", "Cultura DevOps", "Arquitecturas Docker"];
	let counter = 0;
	let currentWord = "";
	let isDeleting = false;

	function type() {
		const target = document.getElementById("text");
		if (!target) return;
		const fullWord = words[counter % words.length];
		
		if (isDeleting) {
			current